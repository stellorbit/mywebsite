{
  "hosting": [
    {
      "target": "main",
      "public": "public",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "cleanUrls": true,
      "headers": [
        {
          "source": "**",
          "headers": [
            {
              "key": "X-Robots-Tag",
              "value": "noindex, nofollow"
            }
          ]
        }
      ]
    },
    {
      "target": "redirect",
      "public": "redirect-public",
      "redirects": [
        {
          "source": "/",
          "destination": "https://www.stellorbit.net/",
          "type": 301
        },
        {
          "source": "/**",
          "destination": "https://www.stellorbit.net/:splat",
          "type": 301
        }
      ]
    }
  ]
}
